    },
    "compose_yaml": {
      "value": "services:\n  api:\n    image: node:22-alpine\n    restart: unless-stopped\n    expose:\n    - \"3000\"\n    depends_on:\n    - db\n    - redis\n    environment:\n      DATABASE_URL: postgres://admin:secret@db:5432/myapp\n      NODE_ENV: production\n      REDIS_URL: redis://redis:6379\n    command:\n    - sh\n    - -c\n    - echo 'API placeholder running' \u0026\u0026 sleep infinity\n    networks:\n    - frontend\n    - backend\n    deploy:\n      resources:\n        limits:\n          cpus: \"0.5\"\n          memory: 512M\n    logging:\n      driver: json-file\n      options:\n        max-file: \"3\"\n        max-size: 10m\n  db:\n    image: postgres:17-alpine\n    restart: always\n    ports:\n    - 5432:5432\n    environment:\n      POSTGRES_DB: myapp\n      POSTGRES_PASSWORD: secret\n      POSTGRES_USER: admin\n    volumes:\n    - pgdata:/var/lib/postgresql/data\n    networks:\n    - backend\n    healthcheck:\n      test:\n      - CMD-SHELL\n      - pg_isready -U admin\n      interval: 10s\n      retries: 5\n    shm_size: 256mb\n  nginx:\n    image: nginx:alpine\n    restart: unless-stopped\n    ports:\n    - 8080:80\n    depends_on:\n    - api\n    networks:\n    - frontend\n    - backend\n    labels:\n      com.example.description: Web frontend\n    healthcheck:\n      test:\n      - CMD\n      - curl\n      - -sf\n      - http://localhost\n      interval: 30s\n      retries: 3\n  redis:\n    image: redis:7-alpine\n    restart: always\n    volumes:\n    - redis_data:/data\n    networks:\n    - backend\n    healthcheck:\n      test:\n      - CMD\n      - redis-cli\n      - ping\n      interval: 10s\nnetworks:\n  backend:\n    driver: bridge\n    internal: true\n    ipam:\n      driver: default\n      config:\n      - subnet: 172.28.0.0/16\n        gateway: 172.28.0.1\n  frontend:\n    driver: bridge\nvolumes:\n  pgdata: {}\n  redis_data: {}\n",
      "type": "string",
      "sensitive": true
    },
